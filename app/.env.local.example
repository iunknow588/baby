# API gateway
VITE_API_BASE_URL=/api

# Coze BFF URI and default identity
VITE_COZE_API_URI=/api/coze
VITE_COZE_BOT_ID=your_coze_bot_id
VITE_COZE_USER_ID=your_local_user_id

# Gateway token for local scripts only (do NOT use VITE_ prefix)
BABY_GATEWAY_TOKEN=replace_with_gateway_token

# SSE options
VITE_SSE_RECONNECT_MS=5000
VITE_SSE_STALE_MS=15000
VITE_SSE_WATCHDOG_MS=3000
VITE_SSE_AUTO_RECOVER_COOLDOWN_MS=8000
