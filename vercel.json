{
  "installCommand": "cd app && npm install",
  "buildCommand": "cd app && npm run build",
  "outputDirectory": "app/dist",
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index?__path="
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index?__path=$1"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  }
}
